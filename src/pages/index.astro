---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("landing-page", "maulid-2026");
if (!entry) {
	throw new Error("Content not found");
}
const content = entry.data;

// Assets helper
const bgHero = "/assets/hero-bg.png";
const imgHotel = "/assets/hotel.png";
const imgPlane = "/assets/plane.png";
const logoKidma = "/assets/kidma-logo-original.png";
---

<Layout title="Umroh Spesial Bulan Maulid 2026 | Kidma Travel">
	<!-- Navbar -->
	<nav
		class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-lg border-b border-gray-100 py-3 shadow-sm transition-all duration-300"
		id="main-nav"
	>
		<div class="container mx-auto px-6 flex justify-between items-center">
			<a href="/" class="flex items-center group">
				<img
					src={logoKidma}
					alt="Kidma Travel Service"
					class="h-12 md:h-14 w-auto object-contain transition-transform group-hover:scale-105"
				/>
			</a>

			<!-- Desktop Menu -->
			<div class="hidden md:flex items-center gap-8">
				<a
					href="#keunggulan"
					class="text-sm font-bold text-dark hover:text-primary transition-colors tracking-wide"
					>Keunggulan</a
				>
				<a
					href="#program"
					class="text-sm font-bold text-dark hover:text-primary transition-colors tracking-wide"
					>Program</a
				>
				<a
					href="#hotel"
					class="text-sm font-bold text-dark hover:text-primary transition-colors tracking-wide"
					>Hotel</a
				>
				<a
					href="#jadwal"
					class="text-sm font-bold text-dark hover:text-primary transition-colors tracking-wide"
					>Jadwal</a
				>
				<a
					href={`https://wa.me/${content.whatsapp.replace(/\D/g, "")}`}
					class="bg-primary text-white px-7 py-2.5 rounded-full text-sm font-bold hover:bg-primary-dark transition-all transform hover:scale-105 shadow-lg shadow-primary/20"
				>
					Daftar Sekarang
				</a>
			</div>

			<!-- Mobile Toggle -->
			<button
				class="md:hidden text-primary p-2 focus:outline-none"
				id="menu-toggle"
				aria-label="Toggle Menu"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-8 w-8"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M4 6h16M4 12h16M4 18h16"></path>
				</svg>
			</button>
		</div>

		<!-- Mobile Menu Overlay -->
		<div
			class="fixed inset-0 bg-primary z-[60] flex flex-col items-center justify-center space-y-8 text-center translate-x-full transition-transform duration-500 md:hidden"
			id="mobile-menu"
		>
			<button class="absolute top-6 right-6 text-white" id="close-toggle">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-10 w-10"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			<img
				src={logoKidma}
				alt="Kidma Logo"
				class="h-20 w-auto brightness-0 invert mb-4"
			/>
			<a href="#keunggulan" class="mobile-link">Keunggulan</a>
			<a href="#program" class="mobile-link">Program</a>
			<a href="#hotel" class="mobile-link">Hotel</a>
			<a href="#jadwal" class="mobile-link">Jadwal</a>
			<a
				href={`https://wa.me/${content.whatsapp.replace(/\D/g, "")}`}
				class="bg-gold text-dark px-10 py-4 rounded-full font-bold text-lg"
				>Daftar Sekarang</a
			>
		</div>
	</nav>

	<main>
		<!-- Hero Section -->
		<section
			class="relative min-h-screen flex items-center justify-center text-white overflow-hidden"
		>
			<div class="absolute inset-0 z-0">
				<img
					src={bgHero}
					class="w-full h-full object-cover"
					alt="Hero Background"
				/>
				<div
					class="absolute inset-0 bg-gradient-to-r from-primary/95 to-primary/40"
				>
				</div>
			</div>

			<div
				class="container mx-auto px-6 relative z-10 grid lg:grid-cols-2 gap-12 items-center pt-28 pb-12"
			>
				<div class="max-w-3xl">
					<div
						class="inline-block bg-gold px-4 py-1 rounded-full text-dark font-bold text-xs mb-6 shadow-lg animate-bounce"
					>
						PROMO MAULID 2026
					</div>
					<h1
						class="text-4xl lg:text-7xl font-playfair font-black leading-tight mb-6"
						set:html={content.hero_title.replace(
							"MAULID 2026",
							'<span class="text-gold">MAULID 2026</span>',
						)}
					/>
					<p class="text-xl lg:text-2xl font-light mb-8 opacity-90">
						{content.hero_subtitle}
					</p>
					<p class="text-lg opacity-80 mb-10 max-w-xl">
						{content.hero_text}
					</p>

					<div class="flex flex-wrap gap-6 mb-12">
						<div
							class="flex items-center gap-3 font-semibold bg-white/10 px-4 py-2 rounded-xl backdrop-blur-sm"
						>
							<span class="text-gold">✈</span> Garuda Indonesia
						</div>
						<div
							class="flex items-center gap-3 font-semibold bg-white/10 px-4 py-2 rounded-xl backdrop-blur-sm"
						>
							<span class="text-gold">🚄</span> Free Kereta Cepat
						</div>
						<div
							class="flex items-center gap-3 font-semibold bg-white/10 px-4 py-2 rounded-xl backdrop-blur-sm"
						>
							<span class="text-gold">🏨</span> Hotel Bintang 5
						</div>
					</div>

					<a
						href={`https://wa.me/${content.whatsapp.replace(/\D/g, "")}`}
						class="inline-flex items-center gap-3 bg-gradient-to-br from-gold to-gold-dark text-white px-8 py-5 rounded-full font-bold text-lg shadow-2xl shadow-gold/20 hover:scale-105 transition-all transform animate-pulse active:scale-95"
					>
						BOOKING SEKARANG VIA WHATSAPP
					</a>
				</div>

				<div
					class="pricing-card bg-white/10 backdrop-blur-xl border border-white/20 p-8 lg:p-12 rounded-[2.5rem] shadow-2xl text-white relative overflow-hidden group"
				>
					<div
						class="absolute top-0 right-0 w-32 h-32 bg-gold/10 rounded-full -mr-16 -mt-16 blur-2xl"
					>
					</div>
					<div class="mb-10 lg:mb-12 border-b border-white/20 pb-8">
						<span
							class="block text-2xl font-bold mb-2 tracking-wide"
							>{content.departure_date}</span
						>
						<span
							class="text-sm opacity-80 bg-gold/20 px-3 py-1 rounded-full inline-block"
							>{content.duration}</span
						>
					</div>
					<div class="space-y-8">
						<div>
							<p
								class="text-xs uppercase tracking-[0.3em] opacity-80 mb-3 font-bold"
							>
								Harga Mulai
							</p>
							<h2
								class="text-5xl lg:text-6xl font-playfair font-black text-gold drop-shadow-lg"
							>
								{content.price}
							</h2>
						</div>
						<div class="h-px bg-white/10"></div>
						<div>
							<span
								class="block text-xs uppercase tracking-[0.3em] opacity-80 mb-2 font-bold"
								>DP CUKUP</span
							>
							<span
								class="text-4xl lg:text-5xl font-black text-white"
								>{content.dp}</span
							>
						</div>
					</div>
					<div
						class="mt-10 lg:mt-12 flex items-center gap-3 text-sm font-bold text-green-400 bg-green-400/10 px-6 py-3 rounded-2xl border border-green-400/20"
					>
						<span
							class="w-6 h-6 bg-green-400 text-dark rounded-full flex items-center justify-center text-[10px]"
							>✓</span
						>
						Seat Terbatas! Segera amankan seat anda.
					</div>
				</div>
			</div>
		</section>

		<!-- Features -->
		<section class="py-32 bg-white" id="keunggulan">
			<div class="container mx-auto px-6 text-center">
				<div
					class="inline-block px-4 py-1 bg-primary/5 text-primary rounded-full text-xs font-bold mb-6 tracking-widest uppercase"
				>
					Keunggulan Kami
				</div>
				<h2
					class="text-4xl lg:text-6xl font-playfair font-bold mb-20 px-4 leading-tight text-dark"
				>
					Kenapa Memilih <br /><span class="text-primary italic"
						>Kidma Travel?</span
					>
				</h2>
				<div class="grid md:grid-cols-3 gap-10 mb-20">
					<div
						class="p-12 bg-gray-50 rounded-[3rem] hover:-translate-y-3 transition-all duration-500 shadow-xl shadow-black/[0.02] border border-gray-100 group hover:border-primary/20"
					>
						<div
							class="w-20 h-20 bg-primary/5 rounded-3xl flex items-center justify-center text-primary mx-auto mb-8 text-4xl group-hover:bg-primary group-hover:text-white transition-all duration-500"
						>
							✈
						</div>
						<h3 class="text-2xl font-bold mb-5 text-dark">
							Garuda Indonesia
						</h3>
						<p class="text-gray-500 leading-relaxed">
							Terbang nyaman & aman dengan maskapai nasional
							terbaik, langsung (direct) ke Tanah Suci.
						</p>
					</div>
					<div
						class="p-12 bg-gray-50 rounded-[3rem] hover:-translate-y-3 transition-all duration-500 shadow-xl shadow-black/[0.02] border border-gray-100 group hover:border-primary/20"
					>
						<div
							class="w-20 h-20 bg-primary/5 rounded-3xl flex items-center justify-center text-primary mx-auto mb-8 text-4xl group-hover:bg-primary group-hover:text-white transition-all duration-500"
						>
							🚄
						</div>
						<h3 class="text-2xl font-bold mb-5 text-dark">
							Free Kereta Cepat
						</h3>
						<p class="text-gray-500 leading-relaxed">
							Mobilitas cepat & mewah antara Makkah - Madinah
							menggunakan Haramain High-Speed Railway.
						</p>
					</div>
					<div
						class="p-12 bg-gray-50 rounded-[3rem] hover:-translate-y-3 transition-all duration-500 shadow-xl shadow-black/[0.02] border border-gray-100 group hover:border-primary/20"
					>
						<div
							class="w-20 h-20 bg-primary/5 rounded-3xl flex items-center justify-center text-primary mx-auto mb-8 text-4xl group-hover:bg-primary group-hover:text-white transition-all duration-500"
						>
							⭐
						</div>
						<h3 class="text-2xl font-bold mb-5 text-dark">
							Hotel Bintang 5
						</h3>
						<p class="text-gray-500 leading-relaxed">
							Penginapan eksklusif berfasilitas premium dengan
							jarak yang sangat dekat ke Masjidil Haram.
						</p>
					</div>
				</div>

				<div class="flex flex-wrap justify-center gap-6">
					{
						[
							"Free Visa",
							"Ticket Confirmed",
							"Tour Leader Profesional",
							"Handling Full Service",
						].map((tag) => (
							<div class="px-8 py-3 bg-white border border-gray-100 rounded-full font-bold text-dark text-sm flex items-center gap-3 shadow-md">
								<span class="w-5 h-5 bg-green-500 text-white rounded-full flex items-center justify-center text-[10px]">
									✓
								</span>
								{tag}
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- Program Detail -->
		<section class="py-32 bg-gray-50" id="program">
			<div class="container mx-auto px-6 max-w-4xl">
				<div
					class="bg-white p-10 md:p-16 rounded-[4rem] shadow-2xl relative overflow-hidden border border-gray-100"
				>
					<div class="absolute top-0 left-0 w-4 h-full bg-primary">
					</div>
					<h2
						class="text-4xl lg:text-5xl font-playfair font-bold mb-12 text-dark"
					>
						Detail Program <br /><span class="text-primary italic"
							>Ibadah Umroh</span
						>
					</h2>
					<div class="grid md:grid-cols-2 gap-x-12 gap-y-6 mb-12">
						{
							[
								{
									label: "Keberangkatan",
									val: content.departure_date,
								},
								{
									label: "Durasi Perjalanan",
									val: content.duration,
								},
								{
									label: "Harga Paket",
									val: `Rp ${content.price}`,
								},
								{
									label: "DP Cukup",
									val: `Rp ${content.dp}`,
									highlight: true,
								},
							].map((item) => (
								<div class="flex justify-between items-center py-6 border-b border-gray-100 last:border-0 md:last:border-b">
									<span class="text-gray-400 font-medium text-sm tracking-widest uppercase">
										{item.label}
									</span>
									<span
										class={`font-bold text-lg ${item.highlight ? "text-primary" : "text-dark"}`}
									>
										{item.val}
									</span>
								</div>
							))
						}
					</div>
					<div
						class="bg-primary/5 text-primary p-6 rounded-3xl text-center font-bold border border-primary/20 border-dashed"
					>
						⚠ SISTEM BOOKING FIRST COME FIRST SERVED - SLOT SANGAT
						TERBATAS
					</div>
				</div>
			</div>
		</section>

		<!-- Accommodation -->
		<section class="py-32 bg-primary text-white" id="hotel">
			<div class="container mx-auto px-6">
				<div class="grid lg:grid-cols-2 gap-16 items-stretch">
					<div
						class="bg-primary-dark p-12 lg:p-20 rounded-[4rem] flex flex-col justify-center shadow-2xl border border-white/5 relative overflow-hidden"
					>
						<div
							class="absolute top-0 right-0 w-64 h-64 bg-gold/5 rounded-full -mr-32 -mt-32 blur-3xl"
						>
						</div>
						<div class="inline-block w-16 h-1 bg-gold mb-10"></div>
						<h2
							class="text-4xl lg:text-6xl font-playfair font-bold mb-12 leading-tight"
						>
							Akomodasi <br /><span class="text-gold"
								>Stay & Pray</span
							>
						</h2>
						<div class="space-y-16">
							<div
								class="relative pl-10 border-l-2 border-gold/30"
							>
								<div
									class="absolute -left-[11px] top-0 w-5 h-5 rounded-full bg-gold shadow-[0_0_20px_rgba(212,175,55,0.6)] border-4 border-primary-dark"
								>
								</div>
								<h3
									class="text-gold text-2xl font-bold mb-4 tracking-wider uppercase text-sm"
								>
									Mecca Residence
								</h3>
								<p
									class="text-2xl lg:text-3xl opacity-90 font-light italic leading-relaxed"
								>
									Le Meridien Tower / Saja (Bintang 5)
								</p>
							</div>
							<div
								class="relative pl-10 border-l-2 border-gold/30"
							>
								<div
									class="absolute -left-[11px] top-0 w-5 h-5 rounded-full bg-gold shadow-[0_0_20px_rgba(212,175,55,0.6)] border-4 border-primary-dark"
								>
								</div>
								<h3
									class="text-gold text-2xl font-bold mb-4 tracking-wider uppercase text-sm"
								>
									Medina Sanctuary
								</h3>
								<p
									class="text-2xl lg:text-3xl opacity-90 font-light italic leading-relaxed"
								>
									Jawharat Arasyid / Setaraf
								</p>
							</div>
						</div>
					</div>
					<div class="grid gap-8">
						<div
							class="rounded-[4rem] overflow-hidden relative shadow-2xl border-2 border-white/20 aspect-video group"
						>
							<img
								src={imgHotel}
								class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
								alt="Luxury Hotel"
							/>
							<div
								class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent opacity-60"
							>
							</div>
							<div class="absolute bottom-10 left-10">
								<span
									class="text-gold text-sm font-bold tracking-[0.4em] uppercase mb-2 block"
									>Interior Suite</span
								>
								<h4 class="text-2xl font-playfair font-bold">
									Bintang 5 Comfort
								</h4>
							</div>
						</div>
						<div class="grid grid-cols-2 gap-8">
							<div
								class="bg-white p-12 rounded-[3.5rem] flex flex-col items-center justify-center text-center shadow-2xl border border-gray-100 group"
							>
								<div class="relative mb-6">
									<div
										class="absolute inset-0 bg-primary/5 rounded-full blur-xl transition-all group-hover:bg-primary/10"
									>
									</div>
									<img
										src="/assets/garuda-logo.png"
										class="h-12 w-auto object-contain relative z-10"
										alt="Garuda Logo"
									/>
								</div>
								<p
									class="text-dark/40 text-[10px] font-black tracking-[0.2em] uppercase"
								>
									Official Flight Partner
								</p>
							</div>
							<div
								class="rounded-[3.5rem] overflow-hidden relative shadow-2xl border-2 border-white/20 group cursor-pointer"
							>
								<img
									src={imgPlane}
									class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
									alt="Garuda Plane"
								/>
								<div
									class="absolute inset-0 bg-gradient-to-br from-primary/20 to-transparent group-hover:bg-transparent transition-all"
								>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Timeline Section -->
		<section class="py-40 bg-gray-50 relative" id="jadwal">
			<div class="container mx-auto px-6 max-w-5xl">
				<div class="text-center mb-28">
					<span
						class="text-primary font-bold tracking-[0.5em] uppercase text-xs mb-6 block"
						>Itinerary Detail</span
					>
					<h2
						class="text-5xl lg:text-7xl font-playfair font-bold text-dark"
					>
						Jadwal Perjalanan
					</h2>
					<div
						class="w-20 h-1.5 bg-gold mx-auto mt-8 rounded-full shadow-lg"
					>
					</div>
				</div>

				<div class="relative">
					{/* Desktop Center Line */}
					<div
						class="absolute left-1/2 top-0 bottom-0 w-px bg-gray-200 hidden lg:block -translate-x-1/2"
					>
					</div>
					{/* Mobile Left Line */}
					<div
						class="absolute left-6 top-0 bottom-0 w-px bg-gray-200 lg:hidden"
					>
					</div>

					<div class="space-y-32 relative">
						{
							content.itinerary.map((item, index) => (
								<div
									class={`flex flex-col lg:flex-row items-center gap-12 lg:gap-24 ${index % 2 !== 0 ? "lg:flex-row-reverse" : ""}`}
								>
									{/* Content Pane */}
									<div class="w-full lg:w-[42%]">
										<div
											class={`bg-white p-10 md:p-14 rounded-[3.5rem] shadow-[0_40px_100px_rgba(0,0,0,0.03)] border border-gray-100 relative group transition-all duration-700 hover:shadow-2xl hover:shadow-primary/5 ${index % 2 === 0 ? "lg:text-right" : "lg:text-left"}`}
										>
											<div
												class={`absolute top-1/2 -translate-y-1/2 w-8 h-px bg-gold/30 hidden lg:block ${index % 2 === 0 ? "-right-8" : "-left-8"}`}
											/>

											<div
												class={`inline-block px-5 py-1.5 rounded-full bg-primary/5 text-primary text-[10px] font-black mb-6 tracking-[0.3em] uppercase border border-primary/10`}
											>
												{item.day}
											</div>
											<h3 class="text-3xl lg:text-4xl font-playfair font-bold mb-6 text-dark group-hover:text-primary transition-colors leading-tight">
												{item.title}
											</h3>
											<p class="text-gray-500 leading-relaxed italic text-base md:text-lg opacity-80">
												{item.desc}
											</p>
										</div>
									</div>

									{/* Central Marker */}
									<div class="absolute left-6 lg:left-1/2 -translate-x-1/2 flex items-center justify-center z-10">
										<div
											class={`w-16 h-16 rounded-full border-8 border-white shadow-2xl flex items-center justify-center text-white text-xs font-black transition-all duration-500 hover:scale-110 active:scale-95 group ${index % 2 === 0 ? "bg-primary" : "bg-gold"}`}
										>
											<span class="drop-shadow-md">
												{item.day.split(" ")[0]}
											</span>
										</div>
									</div>

									{/* Decor Side */}
									<div class="w-full lg:w-[42%] hidden lg:flex items-center justify-center">
										<div
											class={`text-[12rem] font-black text-gray-200/20 leading-none select-none italic font-serif transition-colors group-hover:text-primary/10 ${index % 2 === 0 ? "text-left" : "text-right"}`}
										>
											{index + 1 < 10
												? `0${index + 1}`
												: index + 1}
										</div>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- In Ex Section -->
		<section
			class="py-40 bg-dark-maroon text-white relative overflow-hidden"
			id="fasilitas"
		>
			<div
				class="absolute top-0 right-0 w-96 h-96 bg-primary/20 blur-[150px] -mr-48 -mt-48"
			>
			</div>
			<div class="container mx-auto px-6 relative z-10">
				<div class="grid lg:grid-cols-2 gap-24 lg:gap-32">
					<div class="relative">
